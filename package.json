{
	"name": "latent-line",
	"private": true,
	"version": "0.2.0",
	"type": "module",
	"scripts": {
		"dev": "vite dev --port 5167",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --check . && eslint . --fix --ignore-pattern '**/*.test.*'",
		"lint:fix": "prettier --write . && eslint . --fix --ignore-pattern '**/*.test.*'",
		"format": "prettier --write .",
		"test:unit": "vitest",
		"test": "npm run test:unit -- --run && npm run test:e2e",
		"test:e2e": "playwright test",
		"test:visual": "node scripts/visual-regression.mjs",
		"test:unit:coverage": "vitest run --coverage",
		"test:visual:update": "node scripts/visual-regression.mjs update",
		"bmad:update-dashboard": "node .github/skills/bmad-master/scripts/bmad.mjs dashboard",
		"capture:screenshots": "node scripts/capture-screenshots.mjs",
		"check:i18n": "npx tsx scripts/check-i18n.ts"
	},
	"devDependencies": {
		"@axe-core/playwright": "^4.11.1",
		"@eslint/compat": "^2.0.3",
		"@eslint/js": "^10.0.1",
		"@internationalized/date": "^3.12.0",
		"@lucide/svelte": "^1.6.0",
		"@playwright/test": "^1.58.2",
		"@sveltejs/adapter-auto": "^7.0.1",
		"@sveltejs/adapter-static": "^3.0.10",
		"@sveltejs/kit": "^2.55.0",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@tanstack/table-core": "^8.21.3",
		"@types/node": "^25",
		"@vitest/browser-playwright": "^4.1.1",
		"@vitest/coverage-v8": "^4.1.1",
		"autoprefixer": "^10.4.27",
		"bits-ui": "^2.16.3",
		"embla-carousel-svelte": "^8.6.0",
		"eslint": "^10.1.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.16.0",
		"formsnap": "^2.0.1",
		"globals": "^17.4.0",
		"layerchart": "2.0.0-next.43",
		"mode-watcher": "^1.1.0",
		"paneforge": "^1.0.2",
		"playwright": "^1.58.2",
		"prettier": "^3.8.1",
		"prettier-plugin-svelte": "^3.5.1",
		"shadcn": "^4.1.0",
		"svelte": "^5.55.0",
		"svelte-check": "^4.4.5",
		"svelte-preprocess": "^6.0.3",
		"svelte-sonner": "^1.1.0",
		"sveltekit-superforms": "^2.30.0",
		"typescript": "^6.0.2",
		"typescript-eslint": "^8.57.2",
		"vaul-svelte": "1.0.0-next.7",
		"vite": "^8.0.2",
		"vitest": "^4.1.1",
		"vitest-browser-svelte": "^2.1.0"
	},
	"dependencies": {
		"@medyll/css-base": "^0.1.4",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"shadcn-svelte": "^1.2.3",
		"zod": "^4.3.6"
	}
}
