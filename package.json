{
  "name": "latent-line",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "prepare": "svelte-kit sync || echo ''",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "lint": "prettier --check . && eslint .",
    "format": "prettier --write .",
    "test:unit": "vitest",
    "test": "npm run test:unit -- --run && npm run test:e2e",
    "test:e2e": "playwright test",
    "test:visual": "node scripts/visual-regression.mjs",
    "test:unit:coverage": "vitest run --coverage",
    "test:visual:update": "node scripts/visual-regression.mjs update",
    "bmad:update-dashboard": "node .github/skills/bmad-master/scripts/bmad.mjs dashboard",
    "capture:screenshots": "node scripts/capture-screenshots.mjs"
  },
  "devDependencies": {
    "@eslint/compat": "^2.0.2",
    "@eslint/js": "^10.0.1",
    "@internationalized/date": "^3.11.0",
    "@lucide/svelte": "^0.561.0",
    "@playwright/test": "^1.58.2",
    "@sveltejs/adapter-auto": "^7.0.1",
    "@sveltejs/adapter-static": "^3.0.10",
    "@sveltejs/kit": "^2.53.0",
    "@sveltejs/vite-plugin-svelte": "^6.2.4",
    "@tanstack/table-core": "^8.21.3",
    "@types/node": "^25",
    "@vitest/browser-playwright": "^4.0.18",
    "@vitest/coverage-v8": "^4.0.18",
    "autoprefixer": "^10.4.24",
    "bits-ui": "^2.16.1",
    "embla-carousel-svelte": "^8.6.0",
    "eslint": "^10.0.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-svelte": "^3.15.0",
    "formsnap": "^2.0.1",
    "globals": "^17.3.0",
    "layerchart": "2.0.0-next.43",
    "mode-watcher": "^1.1.0",
    "paneforge": "^1.0.2",
    "playwright": "^1.58.2",
    "prettier": "^3.8.1",
    "prettier-plugin-svelte": "^3.5.0",
    "shadcn": "^3.8.5",
    "svelte": "^5.53.2",
    "svelte-check": "^4.4.3",
    "svelte-preprocess": "^6.0.3",
    "svelte-sonner": "^1.0.7",
    "sveltekit-superforms": "^2.30.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.0",
    "vaul-svelte": "1.0.0-next.7",
    "vite": "^7.3.1",
    "vitest": "^4.0.18",
    "vitest-browser-svelte": "^2.0.2"
  },
  "dependencies": {
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "shadcn-svelte": "^1.1.1",
    "zod": "^4.3.6"
  }
}
